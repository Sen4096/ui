-- ============================
-- Teleport Function
-- ============================
local function teleportTo(x, y, z)
   local char = LocalPlayer.Character
   if not char then return false end
   local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("Head")
   if not root then return false end
   root.CFrame = CFrame.new(x, y, z)
   task.wait(0.1)
   return true
end

-- ============================
-- Fire Nearest Proximity Prompt (within 5 studs)
-- ============================
local function fireNearestPrompt()
   local char = LocalPlayer.Character
   if not char then return end
   
   local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("Head")
   if not root then return end
   
   for _, prompt in pairs(workspace:GetDescendants()) do
      if prompt:IsA("ProximityPrompt") and prompt.Enabled then
         local promptParent = prompt.Parent
         if promptParent then
            local promptPos = promptParent:FindFirstChild("Position")
            local promptPosition
            if promptPos then
               promptPosition = promptPos.Position
            elseif promptParent:IsA("BasePart") then
               promptPosition = promptParent.Position
            else
               promptPosition = promptParent.Position or Vector3.new()
            end
            local distance = (root.Position - promptPosition).Magnitude
            
            if distance <= 5 then
               prompt:InputHoldBegin()
               task.wait(0.1)
               prompt:InputHoldEnd()
               break
            end
         end
      end
   end
end

-- ============================
-- Auto Equip Tool with "dump" in name
-- ============================
local function equipDumpTool()
   local backpack = LocalPlayer.Backpack
   local character = LocalPlayer.Character
   if not character then return false end
   
   -- Check backpack first
   for _, tool in pairs(backpack:GetChildren()) do
      if tool:IsA("Tool") and tool.Name:lower():find("dump") then
         tool.Parent = character
         task.wait(0.3)
         return true
      end
   end
   
   -- Check character inventory
   for _, tool in pairs(character:GetChildren()) do
      if tool:IsA("Tool") and tool.Name:lower():find("dump") then
         return true
      end
   end
   
   return false
end

-- ============================
-- Find NPC Position in PackSelling
-- ============================
local function findNPCPosition(npcName)
   local packSelling = workspace:FindFirstChild("PackSelling")
   if not packSelling then 
      return nil 
   end
   
   for _, child in pairs(packSelling:GetChildren()) do
      if child:IsA("Model") and (child.Name == npcName or string.find(child.Name, npcName)) then
         local rootPart = child:FindFirstChild("HumanoidRootPart")
         local head = child:FindFirstChild("Head")
         local torso = child:FindFirstChild("Torso")
         
         if rootPart then
            return rootPart.Position
         elseif head then
            return head.Position
         elseif torso then
            return torso.Position
         else
            local primaryPart = child.PrimaryPart
            if primaryPart then
               return primaryPart.Position
            else
               local parts = {}
               for _, part in pairs(child:GetDescendants()) do
                  if part:IsA("BasePart") then
                     table.insert(parts, part.Position)
                  end
               end
               if #parts > 0 then
                  local sum = Vector3.new(0,0,0)
                  for _, pos in pairs(parts) do
                     sum = sum + pos
                  end
                  return sum / #parts
               end
            end
         end
      end
   end
   return nil
end

-- ============================
-- Get ATMs
-- ============================
local function getATMs()
   local atms = {}
   local cardFraud = workspace:FindFirstChild("CardFraud")
   if cardFraud then
      local atmFolder = cardFraud:FindFirstChild("ATMs")
      if atmFolder then
         for _, atm in pairs(atmFolder:GetChildren()) do
            atms[#atms + 1] = atm
         end
      end
   end
   return atms
end

-- ============================
-- Get ATM Position
-- ============================
local function getATMPosition(atm)
   local rootPart = atm:FindFirstChild("HumanoidRootPart")
   if rootPart then
      return rootPart.Position
   end
   
   local head = atm:FindFirstChild("Head")
   if head then
      return head.Position
   end
   
   local handle = atm:FindFirstChild("Handle")
   if handle then
      return handle.Position
   end
   
   for _, part in pairs(atm:GetDescendants()) do
      if part:IsA("BasePart") then
         return part.Position
      end
   end
   
   if atm.PrimaryPart then
      return atm.PrimaryPart.Position
   end
   
   return nil
end

