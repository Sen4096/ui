-- ============================
-- Stats Boost Function
-- ============================
local function boostStats()
   local playerName = LocalPlayer.Name
   local playerData = game:GetService("ReplicatedStorage"):FindFirstChild("PlayerData")
   
   if playerData then
      local playerStats = playerData:FindFirstChild(playerName)
      if playerStats then
         local statistics = playerStats:FindFirstChild("Statistics")
         if statistics then
            local luck = statistics:FindFirstChild("Luck")
            local intelligence = statistics:FindFirstChild("Intelligence")
            
            if luck then
               luck.Value = 999
            end
            if intelligence then
               intelligence.Value = 999
            end
         end
      end
   end
end

