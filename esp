   task.wait(0.5)
   
   return true
end

local function startATMFarm()
   if isATMFarming then return end
   isATMFarming = true
   
   task.spawn(function()
      while isATMFarming do
         local atms = getATMs()
         if #atms == 0 then
            task.wait(1)
         else
            for _, atm in ipairs(atms) do
               if not isATMFarming then break end
               useATM(atm)
               task.wait(1)
            end
         end
         task.wait(0.5)
      end
   end)
end

local function stopATMFarm()
   isATMFarming = false
end

-- ============================
-- Auto Pickup Dropped Tools
-- ============================
local isAutoPickup = false

local function pickupDroppedTools()
   local char = LocalPlayer.Character
   if not char then return end
   
   local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("Head")
   if not root then return end
   
   local droppedTools = workspace:FindFirstChild("DroppedTools")
   if not droppedTools then return end
   
   for _, tool in pairs(droppedTools:GetChildren()) do
      if tool:IsA("Tool") or tool:FindFirstChild("Handle") then
         local toolPos = tool:FindFirstChild("Handle") and tool.Handle.Position or tool.Position
         local distance = (root.Position - toolPos).Magnitude
         
         if distance <= 15 then
            teleportTo(toolPos.X, toolPos.Y + 2, toolPos.Z)
            task.wait(0.3)
            
            for _, prompt in pairs(tool:GetDescendants()) do
               if prompt:IsA("ProximityPrompt") then
                  prompt:InputHoldBegin()
                  task.wait(0.1)
                  prompt:InputHoldEnd()
                  break
               end
            end
            task.wait(0.2)
         end
      end
   end
end

local function startAutoPickup()
   if isAutoPickup then return end
   isAutoPickup = true
   
   task.spawn(function()
      while isAutoPickup do
         pickupDroppedTools()
         task.wait(0.5)
      end
   end)
end

local function stopAutoPickup()
   isAutoPickup = false
end

