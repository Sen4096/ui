-- ============================
-- Teleport Function
-- ============================
local function teleportTo(x, y, z)
   local char = LocalPlayer.Character
   if not char then return false end
   local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("Head")
   if not root then return false end
   root.CFrame = CFrame.new(x, y, z)
   task.wait(0.1)
   return true
end

-- ============================
-- Fire Proximity Prompt (FORCED - holds and releases)
-- ============================
local function fireProximityPrompt(prompt)
   if not prompt or not prompt:IsA("ProximityPrompt") then return end
   prompt:InputHoldBegin()
   task.wait(0.15)
   prompt:InputHoldEnd()
   task.wait(0.05)
end

-- ============================
-- Fire Nearest Proximity Prompt (within range)
-- ============================
local function fireNearestPrompt()
   local char = LocalPlayer.Character
   if not char then return end
   
   local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("Head")
   if not root then return end
   
   local nearestPrompt = nil
   local nearestDistance = math.huge
   
   for _, prompt in pairs(workspace:GetDescendants()) do
      if prompt:IsA("ProximityPrompt") and prompt.Enabled then
         local promptParent = prompt.Parent
         if promptParent then
            local promptPos = promptParent:FindFirstChild("Position")
            local promptPosition
            if promptPos then
               promptPosition = promptPos.Position
            elseif promptParent:IsA("BasePart") then
               promptPosition = promptParent.Position
            else
               promptPosition = promptParent.Position or Vector3.new()
            end
            local distance = (root.Position - promptPosition).Magnitude
            
            if distance <= prompt.MaxActivationDistance and distance < nearestDistance then
               nearestDistance = distance
               nearestPrompt = prompt
            end
         end
      end
   end
   
   if nearestPrompt then
      fireProximityPrompt(nearestPrompt)
   end
end

-- ============================
-- Auto Equip Tool (pack, syrup, or candy)
-- ============================
local function autoEquipItem()
   local backpack = LocalPlayer.Backpack
   local character = LocalPlayer.Character
   if not character then return false end
   
   -- Check backpack first for items ending with pack, syrup, or candy
   for _, tool in pairs(backpack:GetChildren()) do
      if tool:IsA("Tool") then
         local name = tool.Name:lower()
         if name:find("pack$") or name:find("syrup$") or name:find("candy$") then
            tool.Parent = character
            task.wait(0.3)
            return true
         end
      end
   end
   
   -- Check character inventory
   for _, tool in pairs(character:GetChildren()) do
      if tool:IsA("Tool") then
         local name = tool.Name:lower()
         if name:find("pack$") or name:find("syrup$") or name:find("candy$") then
            return true
         end
      end
   end
   
   return false
end

-- ============================
-- Find NPC Position in PackSelling (CONSTANT SEARCH)
-- ============================
local function findNPCPosition(npcName)
   local packSelling = workspace:FindFirstChild("PackSelling")
   if not packSelling then 
      return nil 
   end
   
   for _, child in pairs(packSelling:GetChildren()) do
      if child:IsA("Model") and (child.Name == npcName or string.find(child.Name, npcName)) then
         -- Check for TeleportPart first
         local teleportPart = child:FindFirstChild("TeleportPart")
         if teleportPart and teleportPart:IsA("BasePart") then
            return teleportPart.Position
         end
         
         -- Check for HumanoidRootPart
         local rootPart = child:FindFirstChild("HumanoidRootPart")
         if rootPart then
            return rootPart.Position
         end
         
         -- Check for Head
         local head = child:FindFirstChild("Head")
         if head then
            return head.Position
         end
         
         -- Check for Torso
         local torso = child:FindFirstChild("Torso")
         if torso then
            return torso.Position
         end
         
         -- Find any BasePart
         for _, part in pairs(child:GetDescendants()) do
            if part:IsA("BasePart") then
               return part.Position
            end
         end
      end
   end
   return nil
end

-- ============================
-- Get All NPC Positions
-- ============================
local function getAllNPCPositions()
   local npcs = {}
   local packSelling = workspace:FindFirstChild("PackSelling")
   if not packSelling then 
      return npcs
   end
   
   for _, child in pairs(packSelling:GetChildren()) do
      if child:IsA("Model") and (child.Name == "Dan" or child.Name == "Pookie" or string.find(child.Name, "Dan") or string.find(child.Name, "Pookie")) then
         local pos = nil
         local teleportPart = child:FindFirstChild("TeleportPart")
         if teleportPart and teleportPart:IsA("BasePart") then
            pos = teleportPart.Position
         else
            local rootPart = child:FindFirstChild("HumanoidRootPart")
            if rootPart then
               pos = rootPart.Position
            else
               local head = child:FindFirstChild("Head")
               if head then
                  pos = head.Position
               else
                  for _, part in pairs(child:GetDescendants()) do
                     if part:IsA("BasePart") then
                        pos = part.Position
                        break
                     end
                  end
               end
            end
         end
         if pos then
            npcs[child.Name] = pos
         end
      end
   end
   return npcs
end

-- ============================
-- Auto Sell Packs Function (CONSTANT SEARCHING)
-- ============================
local isAutoSelling = false

local function sellToNPC(npcName, npcPos)
   autoEquipItem()
   task.wait(0.5)
   
   teleportTo(npcPos.X, npcPos.Y + 3, npcPos.Z)
   task.wait(1)
   
   fireNearestPrompt()
   task.wait(0.5)
   
   return true
end

local function startAutoSell()
   if isAutoSelling then return end
   isAutoSelling = true
   
   task.spawn(function()
      while isAutoSelling do
         -- Get all current NPC positions
         local currentNPCPositions = getAllNPCPositions()
         
         -- Check each NPC
         for npcName, currentPos in pairs(currentNPCPositions) do
            if not isAutoSelling then break end
            
            local lastPos = lastNPCPositions[npcName]
            
            -- If NPC moved to new location or first time seeing them
            if not lastPos or (currentPos - lastPos).Magnitude > 1 then
               sellToNPC(npcName, currentPos)
               lastNPCPositions[npcName] = currentPos
               task.wait(2)
            end
         end
         
         task.wait(0.5) -- Check every 0.5 seconds for new NPC positions
      end
   end)
end

local function stopAutoSell()
   isAutoSelling = false
end

-- ============================
-- Auto ATM Farm (Only uses dump tool)
-- ============================
local isATMFarming = false

local function useATM()
   -- Only equip dump tool for ATMs
   for _, tool in pairs(LocalPlayer.Backpack:GetChildren()) do
      if tool:IsA("Tool") and tool.Name:lower():find("dump") then
         tool.Parent = LocalPlayer.Character
         break
      end
   end
   task.wait(0.5)
   
   -- Pick a random ATM
   local randomATM = atmLocations[math.random(1, #atmLocations)]
   teleportTo(randomATM.coords[1], randomATM.coords[2] + 3, randomATM.coords[3])
   task.wait(1)
   
   fireNearestPrompt()
   task.wait(0.5)
   
   return true
end

local function startATMFarm()
   if isATMFarming then return end
   isATMFarming = true
   
   task.spawn(function()
      while isATMFarming do
         local currentTime = tick()
         
         -- Check if 3 minutes have passed since last ATM use
         if currentTime - lastATMTime >= 180 then
            useATM()
            lastATMTime = tick()
         end
         
         task.wait(1)
      end
   end)
end

local function stopATMFarm()
   isATMFarming = false
end

-- ============================
-- Auto Pickup Dropped Tools
-- ============================
local isAutoPickup = false

local function pickupDroppedTools()
   local char = LocalPlayer.Character
   if not char then return end
   
   local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("Head")
   if not root then return end
   
   local droppedTools = workspace:FindFirstChild("DroppedTools")
   if not droppedTools then 
      return 
   end
   
   for _, tool in pairs(droppedTools:GetChildren()) do
      if tool:IsA("Tool") or tool:FindFirstChild("Handle") then
         local toolPos = nil
         if tool:IsA("Tool") and tool:FindFirstChild("Handle") then
            toolPos = tool.Handle.Position
         elseif tool:IsA("BasePart") then
            toolPos = tool.Position
         elseif tool:FindFirstChild("Handle") then
            toolPos = tool.Handle.Position
         else
            for _, part in pairs(tool:GetDescendants()) do
               if part:IsA("BasePart") then
                  toolPos = part.Position
                  break
               end
            end
         end
         
         if toolPos then
            local distance = (root.Position - toolPos).Magnitude
            if distance <= 15 then
               teleportTo(toolPos.X, toolPos.Y + 2, toolPos.Z)
               task.wait(0.3)
               
               local promptFound = false
               for _, prompt in pairs(tool:GetDescendants()) do
                  if prompt:IsA("ProximityPrompt") and prompt.Enabled then
                     fireProximityPrompt(prompt)
                     promptFound = true
                     break
                  end
               end
               
               if not promptFound then
                  for _, prompt in pairs(workspace:GetDescendants()) do
                     if prompt:IsA("ProximityPrompt") and prompt.Enabled then
                        local promptParent = prompt.Parent
                        if promptParent then
                           local promptPos = promptParent:FindFirstChild("Position")
                           local promptPosition
                           if promptPos then
                              promptPosition = promptPos.Position
                           elseif promptParent:IsA("BasePart") then
                              promptPosition = promptParent.Position
                           else
                              promptPosition = promptParent.Position or Vector3.new()
                           end
                           local promptDistance = (toolPos - promptPosition).Magnitude
                           if promptDistance <= 3 then
                              fireProximityPrompt(prompt)
                              break
                           end
                        end
                     end
                  end
               end
               task.wait(0.2)
            end
         end
      end
   end
end

local function startAutoPickup()
   if isAutoPickup then return end
   isAutoPickup = true
   
   task.spawn(function()
      while isAutoPickup do
         pickupDroppedTools()
         task.wait(0.5)
      end
   end)
end

local function stopAutoPickup()
   isAutoPickup = false
end

