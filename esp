local function autoEquipItem()
   local character = LocalPlayer.Character
   local backpack = LocalPlayer.Backpack
   if not character then return false end
   local currentTool = character:FindFirstChildOfClass("Tool")
   if currentTool then
      for _, itemName in ipairs(validItems) do
         if currentTool.Name == itemName then return true end
      end
   end
   for _, tool in pairs(backpack:GetChildren()) do
      if tool:IsA("Tool") then
         for _, itemName in ipairs(validItems) do
            if tool.Name == itemName then
               tool.Parent = character
               task.wait(0.3)
               return true
            end
         end
      end
   end
   for _, tool in pairs(character:GetChildren()) do
      if tool:IsA("Tool") then
         for _, itemName in ipairs(validItems) do
            if tool.Name == itemName then return true end
         end
      end
   end
   return false
end

local function autoEquipDumpTool()
   local character = LocalPlayer.Character
   local backpack = LocalPlayer.Backpack
   if not character then return false end
   local currentTool = character:FindFirstChildOfClass("Tool")
   if currentTool and currentTool.Name:lower():find("dump") then return true end
   for _, tool in pairs(backpack:GetChildren()) do
      if tool:IsA("Tool") and tool.Name:lower():find("dump") then
         tool.Parent = character
         task.wait(0.3)
         return true
      end
   end
   for _, tool in pairs(character:GetChildren()) do
      if tool:IsA("Tool") and tool.Name:lower():find("dump") then return true end
   end
   return false
end

-- Find Dan or Pookie by searching for their ProximityPrompt
local function findNPCLocation(npcName)
   local packSelling = workspace:FindFirstChild("PackSelling")
   if not packSelling then return nil, nil end
   
   -- Search through all descendants for the NPC's ProximityPrompt
   for _, prompt in pairs(packSelling:GetDescendants()) do
      if prompt:IsA("ProximityPrompt") then
         -- Traverse up to find the NPC model
         local current = prompt.Parent
         local npcModel = nil
         while current and current ~= packSelling do
            if current:IsA("Model") and (current.Name == npcName or string.lower(current.Name):find(string.lower(npcName))) then
               npcModel = current
               break
            end
            current = current.Parent
         end
         
         if npcModel then
            -- Find the location folder
            local locationCurrent = npcModel.Parent
            local locationName = nil
            while locationCurrent and locationCurrent ~= packSelling do
               locationName = locationCurrent.Name
               locationCurrent = locationCurrent.Parent
            end
            
            -- Get the position from the prompt or NPC
            local pos = nil
            if prompt.Parent and prompt.Parent:IsA("BasePart") then
               pos = prompt.Parent.Position
            elseif npcModel:FindFirstChild("HumanoidRootPart") then
               pos = npcModel.HumanoidRootPart.Position
            elseif npcModel:FindFirstChild("Head") then
               pos = npcModel.Head.Position
            end
            
            if locationName and packSellingLocations[locationName] then
               local coords = packSellingLocations[locationName].coords
               pos = Vector3.new(coords[1], coords[2], coords[3])
            end
            
            if pos then
               return locationName, pos
            end
         end
      end
   end
   return nil, nil
end

local isAutoSelling = false

local function sellToNPC(npcName, locationName, targetPos)
   if not targetPos then return false end
   
   -- Equip item
   if not autoEquipItem() then 
      return false 
   end
   task.wait(0.3)
   
   -- Teleport to location
   teleportTo(targetPos.X, targetPos.Y + 3, targetPos.Z)
   task.wait(0.5)
   
   -- Look at camera ONCE
   lookAtWithCamera(targetPos)
   
   -- Fire the closest prompt multiple times (same as flour - 4 times)
   fireClosestPromptMultiple(4)
   
   -- Reset camera look for next teleport
   resetCameraLook()
   
   return true
end

local function startAutoSell()
   if isAutoSelling then return end
   isAutoSelling = true
   task.spawn(function()
      while isAutoSelling do
         -- Scan for Pookie
         local pookieLocation, pookiePos = findNPCLocation("Pookie")
         if pookiePos then
            local lastLoc = lastNPCLocation["Pookie"]
            if not lastLoc or lastLoc ~= pookieLocation then
               sellToNPC("Pookie", pookieLocation, pookiePos)
               lastNPCLocation["Pookie"] = pookieLocation
               task.wait(2)
            end
         end
         
         if not isAutoSelling then break end
         
         -- Scan for Dan
         local danLocation, danPos = findNPCLocation("Dan")
         if danPos then
            local lastLoc = lastNPCLocation["Dan"]
            if not lastLoc or lastLoc ~= danLocation then
               sellToNPC("Dan", danLocation, danPos)
               lastNPCLocation["Dan"] = danLocation
               task.wait(2)
            end
         end
         
         task.wait(0.5)
      end
   end)
end

local function stopAutoSell()
   isAutoSelling = false
end

