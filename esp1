local function teleportTo(x, y, z)
   local char = LocalPlayer.Character
   if not char then return false end
   local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("Head")
   if not root then return false end
   root.CFrame = CFrame.new(x, y, z)
   task.wait(0.1)
   return true
end

-- Get all prompts with their positions
local function getAllPromptsInRange()
   local char = LocalPlayer.Character
   if not char then return {} end
   
   local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("Head")
   if not root then return {} end
   
   local prompts = {}
   for _, prompt in pairs(workspace:GetDescendants()) do
      if prompt:IsA("ProximityPrompt") and prompt.Enabled then
         local promptParent = prompt.Parent
         if promptParent then
            local promptPos = promptParent:FindFirstChild("Position")
            local promptPosition
            if promptPos then
               promptPosition = promptPos.Position
            elseif promptParent:IsA("BasePart") then
               promptPosition = promptParent.Position
            else
               promptPosition = promptParent.Position or Vector3.new()
            end
            local distance = (root.Position - promptPosition).Magnitude
            if distance <= 20 then
               table.insert(prompts, {prompt = prompt, position = promptPosition, distance = distance, name = promptParent.Name})
            end
         end
      end
   end
   table.sort(prompts, function(a, b) return a.distance < b.distance end)
   return prompts
end

-- Fire the closest prompt
local function fireClosestPrompt()
   local prompts = getAllPromptsInRange()
   if #prompts == 0 then 
      debugPrint("No prompts in range")
      return false 
   end
   
   local closest = prompts[1]
   debugPrint("Firing prompt: " .. (closest.name or "unknown") .. " at distance: " .. closest.distance)
   closest.prompt:InputHoldBegin()
   task.wait(0.15)
   closest.prompt:InputHoldEnd()
   return true
end

-- Fire the closest prompt multiple times
local function fireClosestPromptMultiple(times)
   for i = 1, times do
      fireClosestPrompt()
      task.wait(0.2)
   end
end

-- Auto equip packs in order: Red, Purple, Green, White
local packOrder = {"Red Fun Flour Pack", "Purple Fun Flour Pack", "Green Fun Flour Pack", "White Fun Flour Pack"}
local syrupOrder = {"Raspberry Syrup", "Blackberry Syrup", "Blueberry Syrup", "Goldberry Syrup"}

local function autoEquipItem()
   local character = LocalPlayer.Character
   local backpack = LocalPlayer.Backpack
   if not character then return false end
   
   -- Check if already have a pack equipped
   local currentTool = character:FindFirstChildOfClass("Tool")
   if currentTool then
      for _, itemName in ipairs(packOrder) do
         if currentTool.Name == itemName then 
            debugPrint("Already have pack equipped: " .. currentTool.Name)
            return true 
         end
      end
      for _, itemName in ipairs(syrupOrder) do
         if currentTool.Name == itemName then 
            debugPrint("Already have syrup equipped: " .. currentTool.Name)
            return true 
         end
      end
   end
   
   -- Try to equip packs in order
   for _, itemName in ipairs(packOrder) do
      for _, tool in pairs(backpack:GetChildren()) do
         if tool:IsA("Tool") and tool.Name == itemName then
            tool.Parent = character
            debugPrint("Equipped pack: " .. itemName)
            task.wait(0.3)
            return true
         end
      end
      for _, tool in pairs(character:GetChildren()) do
         if tool:IsA("Tool") and tool.Name == itemName then
            debugPrint("Already have pack in inventory: " .. itemName)
            return true
         end
      end
   end
   
   -- Try to equip syrups in order if no packs
   for _, itemName in ipairs(syrupOrder) do
      for _, tool in pairs(backpack:GetChildren()) do
         if tool:IsA("Tool") and tool.Name == itemName then
            tool.Parent = character
            debugPrint("Equipped syrup: " .. itemName)
            task.wait(0.3)
            return true
         end
      end
      for _, tool in pairs(character:GetChildren()) do
         if tool:IsA("Tool") and tool.Name == itemName then
            debugPrint("Already have syrup in inventory: " .. itemName)
            return true
         end
      end
   end
   
   debugPrint("No pack or syrup found to equip!")
   return false
end

