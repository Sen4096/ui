-- INSTANT PROXIMITY PROMPT - Optimized version with less lag
local function startInstantPrompt()
   if instantPromptRunning then return end
   instantPromptRunning = true
   debugPrint("Instant Proximity Prompts ENABLED")
   
   -- Make all existing prompts instant
   for _, prompt in pairs(workspace:GetDescendants()) do
      if prompt:IsA("ProximityPrompt") then
         if not originalHoldDurations[prompt] then
            originalHoldDurations[prompt] = prompt.HoldDuration
         end
         prompt.HoldDuration = 0
      end
   end
   
   -- Auto scan for new prompts (every 1 second to reduce lag)
   task.spawn(function()
      while instantPromptRunning do
         for _, prompt in pairs(workspace:GetDescendants()) do
            if prompt:IsA("ProximityPrompt") and not originalHoldDurations[prompt] then
               originalHoldDurations[prompt] = prompt.HoldDuration
               prompt.HoldDuration = 0
               debugPrint("New prompt found and set to instant")
            end
         end
         task.wait(1)
      end
   end)
end

local function stopInstantPrompt()
   debugPrint("Instant Proximity Prompts DISABLED")
   instantPromptRunning = false
   for prompt, duration in pairs(originalHoldDurations) do
      if prompt and prompt:IsA("ProximityPrompt") then
         prompt.HoldDuration = duration
      end
   end
   originalHoldDurations = {}
end

-- Find Dan or Pookie location
local function findNPCLocation(npcName)
   local packSelling = workspace:FindFirstChild("PackSelling")
   if not packSelling then 
      debugPrint("PackSelling not found in workspace")
      return nil, nil 
   end
   
   debugPrint("Searching for " .. npcName .. " in PackSelling...")
   
   for _, descendant in pairs(packSelling:GetDescendants()) do
      if descendant:IsA("Model") and (descendant.Name == npcName or string.lower(descendant.Name):find(string.lower(npcName))) then
         debugPrint("Found " .. npcName .. " model: " .. descendant.Name)
         
         local current = descendant.Parent
         local locationName = nil
         while current and current ~= packSelling do
            locationName = current.Name
            current = current.Parent
         end
         debugPrint("Location folder: " .. (locationName or "unknown"))
         
         local pos = nil
         if locationName and packSellingLocations[locationName] then
            local coords = packSellingLocations[locationName].coords
            pos = Vector3.new(coords[1], coords[2], coords[3])
            debugPrint("Using saved coordinates for " .. locationName .. ": " .. tostring(pos))
         elseif descendant:FindFirstChild("HumanoidRootPart") then
            pos = descendant.HumanoidRootPart.Position
            debugPrint("Using NPC HumanoidRootPart position: " .. tostring(pos))
         elseif descendant:FindFirstChild("Head") then
            pos = descendant.Head.Position
            debugPrint("Using NPC Head position: " .. tostring(pos))
         end
         
         if pos then
            return locationName, pos
         end
      end
   end
   debugPrint("Could not find " .. npcName)
   return nil, nil
end

local isAutoSelling = false

local function sellToNPC(npcName, locationName, targetPos)
   debugPrint("=== Selling to " .. npcName .. " at " .. locationName .. " ===")
   debugPrint("Target position: " .. tostring(targetPos))
   
   if not autoEquipItem() then 
      debugPrint("Failed to equip item, aborting sell")
      return false 
   end
   
   debugPrint("Teleporting to target...")
   teleportTo(targetPos.X, targetPos.Y + 3, targetPos.Z)
   task.wait(0.8)
   
   debugPrint("Firing proximity prompts...")
   fireClosestPromptMultiple(5)
   
   debugPrint("=== Done selling to " .. npcName .. " ===")
   return true
end

local function startAutoSell()
   if isAutoSelling then return end
   isAutoSelling = true
   debugPrint("Auto Sell ENABLED")
   task.spawn(function()
      while isAutoSelling do
         debugPrint("Scanning for Pookie...")
         local pookieLocation, pookiePos = findNPCLocation("Pookie")
         if pookiePos then
            local lastLoc = lastNPCLocation["Pookie"]
            if not lastLoc or lastLoc ~= pookieLocation then
               sellToNPC("Pookie", pookieLocation, pookiePos)
               lastNPCLocation["Pookie"] = pookieLocation
               task.wait(3)
            else
               debugPrint("Pookie still at same location: " .. pookieLocation)
            end
         end
         
         if not isAutoSelling then break end
         
         debugPrint("Scanning for Dan...")
         local danLocation, danPos = findNPCLocation("Dan")
         if danPos then
            local lastLoc = lastNPCLocation["Dan"]
            if not lastLoc or lastLoc ~= danLocation then
               sellToNPC("Dan", danLocation, danPos)
               lastNPCLocation["Dan"] = danLocation
               task.wait(3)
            else
               debugPrint("Dan still at same location: " .. danLocation)
            end
         end
         
         task.wait(1)
      end
   end)
end

local function stopAutoSell()
   isAutoSelling = false
   debugPrint("Auto Sell DISABLED")
end

